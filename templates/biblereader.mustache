{{#js}}
require(['mod_biblereader/biblereader'], function(Biblereader) {
    // Biblereader.init(document.querySelector('#mod_biblereader-biblereader-wrapper-{{uniqid}}'));
    Biblereader.init('{{uniqid}}');
});
{{/js}}
