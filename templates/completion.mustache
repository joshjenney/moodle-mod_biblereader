<!-- mod_biblereader/completion -->
<div class="biblereader" style="max-width: 500px; margin: 0 auto;">

  <h1>{{#str}} modulename, biblereader {{/str}}</h1>
  <h4>{{#str}} reading_completed, biblereader {{/str}}</h4>

  <!-- &#9989; &#x2705; -->
  <div style="display: flex; flex-direction: column;">
    <ul style="list-style: none; column-count: 2; column-gap: 2rem;">
      {{#completed}}
        {{#checked}}<li>☑ {{ chapter }}</li>{{/checked}}
        <!-- {{^checked}}<li>☐ {{ chapter }}</li>{{/checked}} -->
      {{/completed}}
    </ul>
  </div>

  <div>
    <div style="display: flex;">
      <a style="flex: 1;" class="btn btn-secondary" href="{{ biblereader_href }}">↖{{#str}} back, biblereader {{/str}}</a>
    </div>
    <!--
    <div style="display: flex;">
      <a style="flex: 1;" class="btn btn-light">&lt; {{#str}} back, biblereader {{/str}}</a>
      <a style="flex: 1;" class="btn btn-light">{{#str}} next_passage, biblereader {{/str}} &gt;</a>
    </div>
    -->
  </div>

</div>
<!-- /mod_biblereader/completion -->
